<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Live DSL - Meta DSL</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" type="text/css" href="/style.css">
    <% if (locals.isProduction) { %>
        <link rel="stylesheet" href="/assets/main.css">
    <% } %>
</head>

<body class="flex flex-col font-sans h-screen overflow-hidden">

    <header class="bg-gray-800 p-2 border-b border-gray-700 flex justify-between items-center text-sm">
        <div class="text-lg text-white font-bold flex items-center gap-4">
            <a href="/" class="text-gray-400 hover:text-white transition-colors" title="Back to Home">🏠</a>
            Meta DSL Editor
        </div>
        <button id="btn-reset" class="bg-red-600 hover:bg-red-500 text-white text-xs px-3 py-1 rounded">Reset</button>
    </header>

    <main class="flex-1 flex overflow-hidden relative" id="workspace">
        <%- include('../components/windowMetaDSL'); %>
    </main>

    <% if (locals.isProduction) { %>
        <script type="module" src="/assets/main.js"></script>
    <% } else { %>
        <script type="module" src="http://localhost:5173/@vite/client"></script>
        <script type="module" src="http://localhost:5173/src/main.ts"></script>
    <% } %>
</body>

</html>