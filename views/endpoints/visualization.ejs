<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Live DSL - Visualization</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" type="text/css" href="/style.css">
    <% if (locals.isProduction) { %>
        <link rel="stylesheet" href="/assets/main.css">
    <% } %>
</head>

<body class="flex flex-col font-sans h-screen overflow-hidden bg-gray-900 text-white">

    <header class="bg-gray-800 p-2 border-b border-gray-700 flex items-center gap-4 text-sm">
        <a href="/" class="text-gray-400 hover:text-white transition-colors text-lg" title="Back to Home">🏠</a>
        <span class="font-bold text-lg">Visualizer</span>
    </header>

    <main class="flex-1 flex overflow-hidden relative" id="workspace">
        <%- include('../components/windowVisualizer'); %>
    </main>

    <% if (locals.isProduction) { %>
        <script type="module" src="/assets/main.js"></script>
    <% } else { %>
        <script type="module" src="http://localhost:5173/@vite/client"></script>
        <script type="module" src="http://localhost:5173/src/main.ts"></script>
    <% } %>
</body>

</html>