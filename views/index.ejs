<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Live DSL Builder</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" type="text/css" href="/style.css">
</head>

<body>
    <div class="bg-gray-900 h-screen flex flex-col items-center justify-center text-white font-sans">

        <div class="text-center w-full max-w-2xl">
            <h1 class="text-4xl font-bold mb-4 text-blue-400">Live DSL Builder</h1>

            <div class="grid grid-cols-2 gap-4">
                <a href="/full" class="bg-gray-800 hover:bg-gray-700 border border-gray-600 p-4 rounded-lg flex flex-col col-span-2">
                    <span class="text-lg font-bold text-white">Full IDE</span>
                    <span class="text-sm text-gray-400">Metal DSL + Application DSL + Visualization</span>
                </a>

                <a href="/metadsl" target="_blank" class="bg-blue-900 hover:bg-blue-800 border border-blue-700 p-4 rounded-lg flex flex-col">
                    <span class="text-lg font-bold text-white">Meta DSL</span>
                    <span class="text-sm text-blue-300">Meta DSL editor only</span>
                </a>

                <a href="/applicationdsl" target="_blank" class="bg-indigo-900 hover:bg-indigo-800 border border-indigo-700 p-4 rounded-lg flex flex-col">
                    <span class="text-lg font-bold text-white">Application DSL</span>
                    <span class="text-sm text-indigo-300">Application DSL editor only</span>
                </a>

                <a href="/visualization" target="_blank" class="bg-green-900 hover:bg-green-800 border border-green-700 p-4 rounded-lg flex flex-col col-span-2">
                    <span class="text-lg font-bold text-white">Visualization</span>
                    <span class="text-sm text-green-300">Abstract Syntax Tree & Railroad Diagram</span>
                </a>
            </div>
        </div>
    </div>
</body>

</html>